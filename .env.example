# Шаблон настроек. Скопируй в .env.local и впиши свой пароль приложения.
# Файл .env.local в git не попадает — он в .gitignore.

# Почта для отправки заявок (Яндекс)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=mirtimoschenko@yandex.ru

# ВАЖНО: не обычный пароль от почты, а «пароль приложения»
# из Яндекс ID → Безопасность → Пароли приложений → Почта
SMTP_PASS=

# Куда слать заявки (по умолчанию — на SMTP_USER)
LEAD_TO=mirtimoschenko@yandex.ru
